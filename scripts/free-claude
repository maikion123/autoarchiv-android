#!/bin/bash
# free-claude: Claude Code mit isoliertem Free-Profile + OpenRouter

set -euo pipefail

readonly USER=$(whoami)
readonly HOME_DIR=$(eval echo ~$USER)
readonly CLAUDE_DIR="${HOME_DIR}/.claude"
readonly FREE_PROFILE="${CLAUDE_DIR}/profiles/free"
readonly SETTINGS_FREE="${FREE_PROFILE}/settings.json"
readonly OPENROUTER_CONFIG="${FREE_PROFILE}/.config/openrouter/config"

# Farben
readonly GREEN='\033[0;32m'
readonly BLUE='\033[0;34m'
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_error() { echo -e "${RED}[✗]${NC} $*" >&2; exit 1; }
log_success() { echo -e "${GREEN}[✓]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[!]${NC} $*"; }

# Überprüfe ob Free-Profile existiert
if [ ! -f "$SETTINGS_FREE" ]; then
    log_error "Free-Profile nicht gefunden: $SETTINGS_FREE"
    log_error "Führe aus: setup-claude"
fi

log_success "Claude Free aktiviert (isoliert)"
log_success "  Profile: ${FREE_PROFILE}/"

# Erstelle Symlink auf active settings.json (isoliert!)
ln -sf "$SETTINGS_FREE" "${CLAUDE_DIR}/settings.json" 2>/dev/null || {
    # Fallback: Kopiere statt Symlink
    cp "$SETTINGS_FREE" "${CLAUDE_DIR}/settings.json"
}

# Lade OpenRouter-Konfiguration (isoliert im Free-Profile!)
if [ ! -f "$OPENROUTER_CONFIG" ]; then
    log_error "OpenRouter Config nicht gefunden: $OPENROUTER_CONFIG"
    log_error "Führe aus: setup-claude"
fi

source "$OPENROUTER_CONFIG"

# Exportiere Umgebungsvariablen für Claude Code (OpenRouter)
export ANTHROPIC_BASE_URL="https://openrouter.ai/api/v1"
export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-}"
export ANTHROPIC_API_KEY=""

# Validiere API Key
if [ -z "$ANTHROPIC_AUTH_TOKEN" ]; then
    log_error "ANTHROPIC_AUTH_TOKEN ist leer in: $OPENROUTER_CONFIG"
fi

echo "   API: OpenRouter ✓"

# Zeige Modell-Info
CURRENT_MODEL=$(jq -r '.model' "$SETTINGS_FREE" 2>/dev/null || echo "unknown")
echo "   Modell: $CURRENT_MODEL"
echo ""
echo "💡 Modell wechseln: free-claude-model"
echo ""

# Starte Claude Code (nutzt die isolierte settings.json + OpenRouter Env-Vars)
exec claude code "$@"
