#!/bin/bash
# free-claude: Start Claude Code with Ollama (local) or OpenRouter (cloud)

set -euo pipefail

readonly HOME_DIR=$(eval echo ~$(whoami))
readonly CONFIG_DIR="${HOME_DIR}/.config/claude-free"
readonly CONFIG_FILE="${CONFIG_DIR}/method"

# Colors
readonly BLUE='\033[0;34m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly RED='\033[0;31m'
readonly NC='\033[0m'

log_error() { echo -e "${RED}❌${NC} $*" >&2; }
log_success() { echo -e "${GREEN}✓${NC} $*"; }
log_info() { echo -e "${BLUE}ℹ${NC} $*"; }

# Determine which method to use
if [ -f "$CONFIG_FILE" ]; then
    METHOD=$(cat "$CONFIG_FILE")
else
    log_error "Config not found: $CONFIG_FILE"
    log_info "Run: setup-claude"
    exit 1
fi

case "$METHOD" in
    ollama)
        # Check if Ollama is running
        if ! curl -s http://localhost:11434/api/tags > /dev/null 2>&1; then
            log_error "Ollama is not running"
            log_info "Start Ollama:"
            log_info "  macOS/Windows: Open the Ollama app"
            log_info "  Linux: ollama serve"
            exit 1
        fi

        # Load Ollama config
        source "${CONFIG_DIR}/ollama"
        if [ -z "${OLLAMA_MODEL:-}" ]; then
            log_error "OLLAMA_MODEL not set"
            exit 1
        fi

        export ANTHROPIC_BASE_URL="http://localhost:11434/v1"
        export ANTHROPIC_API_KEY="ollama"
        export ANTHROPIC_MODEL="${OLLAMA_MODEL}"

        log_success "Claude Free (Ollama - Local)"
        log_info "Model: $OLLAMA_MODEL"
        log_info "Endpoint: $ANTHROPIC_BASE_URL"
        ;;

    openrouter)
        # Load OpenRouter API Key
        if [ ! -f "${CONFIG_DIR}/openrouter" ]; then
            log_error "OpenRouter config not found: ${CONFIG_DIR}/openrouter"
            log_info "Run: setup-claude"
            exit 1
        fi

        source "${CONFIG_DIR}/openrouter"

        if [ -z "${OPENROUTER_API_KEY:-}" ]; then
            log_error "OPENROUTER_API_KEY is empty"
            exit 1
        fi

        export ANTHROPIC_BASE_URL="https://openrouter.ai/api/v1"
        export ANTHROPIC_API_KEY="$OPENROUTER_API_KEY"

        log_success "Claude Free (OpenRouter - Cloud)"
        log_info "Endpoint: $ANTHROPIC_BASE_URL"
        ;;

    *)
        log_error "Unknown method: $METHOD"
        log_info "Valid methods: ollama, openrouter"
        exit 1
        ;;
esac

echo ""

# Start Claude Code
exec claude code "$@"
