#!/bin/bash
# free-claude: Starte Claude Code mit Free-Profil (OpenRouter)
# Setzt ~/.claude/settings.json mit korrekten Free-Einstellungen

set -e

CLAUDE_DIR="${HOME}/.claude"
SETTINGS_FREE="${CLAUDE_DIR}/settings.free.json"
SETTINGS_ACTIVE="${CLAUDE_DIR}/settings.json"

# Überprüfe ob Free-Profile existiert
if [ ! -f "$SETTINGS_FREE" ]; then
  echo "❌ Fehler: Free-Profil nicht gefunden!"
  echo "   Bitte zuerst ausführen: setup-claude"
  exit 1
fi

echo "🆓 Claude Free (OpenRouter) aktiviert"

# KRITISCH: Kopiere Free-Profil zu aktiven Settings
mkdir -p "$CLAUDE_DIR"
cp "$SETTINGS_FREE" "$SETTINGS_ACTIVE"

# Extrahiere und setze Umgebungsvariablen
if command -v jq &> /dev/null; then
  ANTHROPIC_BASE_URL=$(jq -r '.env.ANTHROPIC_BASE_URL // empty' "$SETTINGS_ACTIVE" 2>/dev/null || true)
  ANTHROPIC_AUTH_TOKEN=$(jq -r '.env.ANTHROPIC_AUTH_TOKEN // empty' "$SETTINGS_ACTIVE" 2>/dev/null || true)

  if [ -n "$ANTHROPIC_BASE_URL" ] && [ "$ANTHROPIC_BASE_URL" != "null" ]; then
    export ANTHROPIC_BASE_URL
    export ANTHROPIC_AUTH_TOKEN
    export ANTHROPIC_API_KEY=""  # MUSS LEER sein!

    echo "   API: OpenRouter ✓"
    echo "   Model: $(jq -r '.model // "unknown"' "$SETTINGS_ACTIVE")"
  else
    echo "   ⚠️  OpenRouter nicht korrekt konfiguriert"
  fi
else
  echo "   Config geladen von: $SETTINGS_FREE"
fi

echo ""

# Starte Claude Code
exec claude code "$@"
