#!/bin/bash
# free-claude: Starte Claude Code mit OpenRouter Free (ohne bestehenden Login zu beeinflussen)

set -e

# Überprüfe, ob OpenRouter API Key gesetzt ist
# Versuche zuerst aus Umgebung zu laden, dann aus Shell-Dateien
if [ -z "$OPENROUTER_API_KEY" ]; then
  # Versuche aus ~/.bashrc oder ~/.bash_profile zu laden
  if [ -f ~/.bashrc ]; then
    source ~/.bashrc 2>/dev/null || true
  fi
  if [ -z "$OPENROUTER_API_KEY" ] && [ -f ~/.bash_profile ]; then
    source ~/.bash_profile 2>/dev/null || true
  fi
  if [ -z "$OPENROUTER_API_KEY" ] && [ -f ~/.profile ]; then
    source ~/.profile 2>/dev/null || true
  fi
fi

# Falls immer noch nicht gesetzt, zeige Fehler
if [ -z "$OPENROUTER_API_KEY" ]; then
  echo "❌ Fehler: OPENROUTER_API_KEY nicht gesetzt"
  echo ""
  echo "Setze die Variable in ~/.bashrc oder ~/.bash_profile:"
  echo "  export OPENROUTER_API_KEY='sk-or-v1-...'"
  echo ""
  echo "Oder aktuell in dieser Shell:"
  echo "  export OPENROUTER_API_KEY='sk-or-v1-...'"
  exit 1
fi

echo "🆓 OpenRouter Free aktiviert"
echo "   API: openrouter.ai/api"
echo "   Model: openrouter/free"
echo ""

# Erstelle temporäre Konfiguration für diese Session (nicht permanent!)
# Nutze --settings Flag um nur für diese Invocation die OpenRouter Konfiguration zu setzen
# Dies beeinträchtigt nicht bestehende claude.ai Authentifizierung
SETTINGS_JSON=$(cat <<EOF
{
  "model": "openrouter/free",
  "provider": "openrouter",
  "env": {
    "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
    "ANTHROPIC_AUTH_TOKEN": "$OPENROUTER_API_KEY",
    "ANTHROPIC_API_KEY": ""
  }
}
EOF
)

# Starte Claude Code mit temporären Settings
# --settings überschreibt nur für diese Session, ohne permanent zu speichern
exec claude code --settings "$SETTINGS_JSON" "$@"
