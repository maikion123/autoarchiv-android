#!/bin/bash
# free-claude: Starte Claude Code mit OpenRouter Free

set -e

SETTINGS_FILE="${HOME}/.claude/settings.local.json"

# Stelle sicher, dass settings.local.json existiert
if [ ! -f "$SETTINGS_FILE" ]; then
  mkdir -p "$(dirname "$SETTINGS_FILE")"
  echo '{}' > "$SETTINGS_FILE"
fi

# Backup erstellen (optional, für Sicherheit)
BACKUP_FILE="${SETTINGS_FILE}.backup"
cp "$SETTINGS_FILE" "$BACKUP_FILE"

# Überprüfe, ob OpenRouter API Key gesetzt ist
# Versuche zuerst aus Umgebung zu laden, dann aus Shell-Dateien
if [ -z "$OPENROUTER_API_KEY" ]; then
  # Versuche aus ~/.bashrc oder ~/.bash_profile zu laden
  if [ -f ~/.bashrc ]; then
    source ~/.bashrc 2>/dev/null || true
  fi
  if [ -z "$OPENROUTER_API_KEY" ] && [ -f ~/.bash_profile ]; then
    source ~/.bash_profile 2>/dev/null || true
  fi
  if [ -z "$OPENROUTER_API_KEY" ] && [ -f ~/.profile ]; then
    source ~/.profile 2>/dev/null || true
  fi
fi

# Falls immer noch nicht gesetzt, zeige Fehler
if [ -z "$OPENROUTER_API_KEY" ]; then
  echo "❌ Fehler: OPENROUTER_API_KEY nicht gesetzt"
  echo ""
  echo "Setze die Variable in ~/.bashrc oder ~/.bash_profile:"
  echo "  export OPENROUTER_API_KEY='sk-or-v1-...'"
  echo ""
  echo "Oder aktuell in dieser Shell:"
  echo "  export OPENROUTER_API_KEY='sk-or-v1-...'"
  exit 1
fi

# Konfiguriere für OpenRouter Free
jq '.model = "openrouter/free" |
    .provider = "openrouter" |
    .env.OPENROUTER_API_KEY = env.OPENROUTER_API_KEY |
    .env.ANTHROPIC_BASE_URL = "https://openrouter.ai/api/v1"' \
  "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" && \
  mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"

echo "🆓 OpenRouter Free aktiviert"
echo "   API: openrouter.ai"
echo "   Model: free"

# Starte Claude Code
exec claude code "$@"

# Hinweis: Das Backup bleibt erhalten, falls du manuell zurückschalten möchtest
# Restore: cp "$BACKUP_FILE" "$SETTINGS_FILE"
