#!/bin/bash
# pro-claude: Starte Claude Code mit Anthropic Pro (via claude.ai subscription)
# Nutzt bestehende claude.ai Authentifizierung, keine externen Keys

echo "🚀 Claude Pro aktiviert (Opus 4.7)"
echo "   API: Anthropic (via claude.ai subscription)"
echo ""

# Stelle sicher, dass du mit claude.ai angemeldet bist (falls nicht, wird Claude Code auffordern)
# Keine Konfiguration nötig - nutzt deinen bestehenden claude.ai Token

# Starte Claude Code normal mit deiner Subscription
exec claude code "$@"
