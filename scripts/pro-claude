#!/bin/bash
# pro-claude: Starte Claude Code mit Anthropic Pro

set -e

SETTINGS_FILE="${HOME}/.claude/settings.local.json"

# Stelle sicher, dass settings.local.json existiert
if [ ! -f "$SETTINGS_FILE" ]; then
  mkdir -p "$(dirname "$SETTINGS_FILE")"
  echo '{}' > "$SETTINGS_FILE"
fi

# Backup erstellen (optional, für Sicherheit)
BACKUP_FILE="${SETTINGS_FILE}.backup"
cp "$SETTINGS_FILE" "$BACKUP_FILE"

# Konfiguriere für Anthropic Pro
jq '.model = "claude-opus-4-7" |
    .provider = "anthropic" |
    .env.ANTHROPIC_API_KEY = env.ANTHROPIC_API_KEY |
    .env.ANTHROPIC_BASE_URL = "https://api.anthropic.com/v1"' \
  "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" && \
  mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"

echo "🚀 Claude Pro aktiviert (Opus 4.7)"
echo "   API: Anthropic"

# Unsetze ANTHROPIC_API_KEY um Auth-Konflikt zu vermeiden
# (maik logged sich mit claude.ai ein, nicht mit API Key)
unset ANTHROPIC_API_KEY

# Starte Claude Code
exec claude code "$@"

# Hinweis: Das Backup bleibt erhalten, falls du manuell zurückschalten möchtest
# Restore: cp "$BACKUP_FILE" "$SETTINGS_FILE"
