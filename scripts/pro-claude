#!/bin/bash
# pro-claude: Start Claude Code Pro with OAuth

# Clear any OpenRouter/Ollama environment variables to use Claude Pro directly
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_API_KEY
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_MODEL
unset OPENROUTER_API_KEY
unset OPENROUTER_MODEL

exec claude code "$@"
