#!/bin/bash
# pro-claude: Claude Code mit Pro-Profile (OAuth)

set -euo pipefail

readonly USER=$(whoami)
readonly HOME_DIR=$(eval echo ~$USER)
readonly CLAUDE_DIR="${HOME_DIR}/.claude"
readonly SETTINGS_PRO="${CLAUDE_DIR}/settings.pro.json"
readonly SETTINGS_ACTIVE="${CLAUDE_DIR}/settings.json"
readonly CREDENTIALS="${CLAUDE_DIR}/.credentials.json"
readonly CREDENTIALS_BAK="${CLAUDE_DIR}/.credentials.json.bak"

# Farben
readonly GREEN='\033[0;32m'
readonly BLUE='\033[0;34m'
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_error() { echo -e "${RED}[✗]${NC} $*" >&2; exit 1; }
log_success() { echo -e "${GREEN}[✓]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[!]${NC} $*"; }

# Überprüfe ob Pro-Profile existiert
if [ ! -f "$SETTINGS_PRO" ]; then
    log_error "Pro-Profile nicht gefunden! Führe 'setup-claude' aus."
fi

log_success "Claude Pro aktiviert"

# Kopiere Pro-Profile zu aktiven Settings
mkdir -p "$CLAUDE_DIR"
cp "$SETTINGS_PRO" "$SETTINGS_ACTIVE"

# Stelle OAuth Credentials wieder her wenn nötig
# (Credentials können durch Claude Code Update verloren gehen)
if [ ! -f "$CREDENTIALS" ] && [ -f "$CREDENTIALS_BAK" ]; then
    log_warn "OAuth-Tokens wiederherstellen..."
    cp "$CREDENTIALS_BAK" "$CREDENTIALS"
    chmod 600 "$CREDENTIALS"
    log_success "OAuth-Tokens wiederhergestellt"
fi

# Überprüfe ob Credentials existieren
if [ ! -f "$CREDENTIALS" ]; then
    log_warn "Keine gespeicherten OAuth-Tokens gefunden"
    echo ""
    echo "Beim Start werden Sie aufgefordert, sich mit /login anzumelden."
    echo "Dies ist normal beim ersten Start."
    echo ""
fi

# Starte Claude Code
exec claude code "$@"

