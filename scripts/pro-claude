#!/bin/bash
# pro-claude: Claude Code mit isoliertem Pro-Profile

set -euo pipefail

readonly USER=$(whoami)
readonly HOME_DIR=$(eval echo ~$USER)
readonly CLAUDE_DIR="${HOME_DIR}/.claude"
readonly PRO_PROFILE="${CLAUDE_DIR}/profiles/pro"
readonly SETTINGS_PRO="${PRO_PROFILE}/settings.json"
readonly CREDENTIALS="${PRO_PROFILE}/.credentials.json"

# Farben
readonly GREEN='\033[0;32m'
readonly BLUE='\033[0;34m'
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_error() { echo -e "${RED}[✗]${NC} $*" >&2; exit 1; }
log_success() { echo -e "${GREEN}[✓]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[!]${NC} $*"; }

# Überprüfe ob Pro-Profile existiert
if [ ! -f "$SETTINGS_PRO" ]; then
    log_error "Pro-Profile nicht gefunden: $SETTINGS_PRO"
    log_error "Führe aus: setup-claude"
fi

log_success "Claude Pro aktiviert (isoliert)"
log_success "  Profile: ${PRO_PROFILE}/"

# Erstelle Symlink auf active settings.json (isoliert!)
# Dies stellt sicher, dass pro-claude SEINE eigenen settings.json nutzt
ln -sf "$SETTINGS_PRO" "${CLAUDE_DIR}/settings.json" 2>/dev/null || {
    # Fallback: Kopiere statt Symlink
    cp "$SETTINGS_PRO" "${CLAUDE_DIR}/settings.json"
}

# Zeige Modell und Credentials-Info
CURRENT_MODEL=$(jq -r '.model' "$SETTINGS_PRO" 2>/dev/null || echo "unknown")
echo "   Modell: $CURRENT_MODEL"

if [ ! -f "$CREDENTIALS" ]; then
    log_warn "Beim ersten Start: /login für OAuth Authentifizierung"
else
    log_success "OAuth Credentials gefunden"
fi

echo ""

# Starte Claude Code (nutzt die isolierte settings.json)
exec claude code "$@"
