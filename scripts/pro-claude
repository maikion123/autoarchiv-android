#!/bin/bash
# pro-claude: Starte Claude Code mit Pro-Profil (Anthropic)
# Setzt ~/.claude/settings.json mit korrekten Pro-Einstellungen

set -e

CLAUDE_DIR="${HOME}/.claude"
SETTINGS_PRO="${CLAUDE_DIR}/settings.pro.json"
SETTINGS_ACTIVE="${CLAUDE_DIR}/settings.json"

# Überprüfe ob Pro-Profile existiert
if [ ! -f "$SETTINGS_PRO" ]; then
  echo "❌ Fehler: Pro-Profil nicht gefunden!"
  echo "   Bitte zuerst ausführen: setup-claude"
  exit 1
fi

echo "🚀 Claude Pro aktiviert"

# KRITISCH: Kopiere Pro-Profil zu aktiven Settings
mkdir -p "$CLAUDE_DIR"
cp "$SETTINGS_PRO" "$SETTINGS_ACTIVE"

# Extrahiere API Key falls vorhanden
if command -v jq &> /dev/null; then
  ANTHROPIC_API_KEY=$(jq -r '.env.ANTHROPIC_API_KEY // empty' "$SETTINGS_PRO" 2>/dev/null || true)

  if [ -n "$ANTHROPIC_API_KEY" ] && [ "$ANTHROPIC_API_KEY" != "null" ]; then
    export ANTHROPIC_API_KEY
    echo "   Auth: API Key ✓"
  else
    echo "   Auth: OAuth (Browser) ✓"
  fi

  echo "   Model: $(jq -r '.model // "claude-opus-4-7"' "$SETTINGS_ACTIVE")"
else
  echo "   Config geladen von: $SETTINGS_PRO"
fi

echo ""

# Cleanup
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_AUTH_TOKEN

# Starte Claude Code
exec claude code "$@"
