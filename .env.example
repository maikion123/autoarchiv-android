# Supabase (legacy, aktuell nicht mehr für Upload-Analyse verwendet)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Auth-Backend (NEU – erforderlich für api-server.mjs)
JWT_SECRET=             # Langer zufälliger String, z.B.: openssl rand -hex 64

# SMTP-Konfiguration
SMTP_HOST=              # z.B. smtp.gmail.com oder mail.mailjet.com
SMTP_PORT=587           # 587 = STARTTLS, 465 = SSL
SMTP_USER=              # Dein SMTP-Benutzername / E-Mail
SMTP_PASSWORD=          # Dein SMTP-Passwort / App-Passwort
SMTP_FROM=noreply@nextkm.de   # Absender-Adresse
SMTP_SECURE=false       # true nur bei Port 465

# Datenbank
DB_PATH=/srv/projects/autoarchiv/data/autoarchiv.db

# Server-seitiges Dokumentarchiv
STORAGE_PATH=/srv/projects/autoarchiv/storage

# API-Server
API_PORT=3001
FRONTEND_ORIGIN=https://nextkm.de
COOKIE_DOMAIN=nextkm.de

# Push-Benachrichtigungen via ntfy
NTFY_ENABLED=false
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=autoarchiv-kevin-BITTE-LANG-ZUFAELLIG-MACHEN
NTFY_TOKEN=
NTFY_DEFAULT_PRIORITY=default
PUBLIC_APP_URL=https://nextkm.de

# Dokumentanalyse (Ollama deaktiviert – verwendet schnelle lokale Regex-Analyse)
# Ollama-Konfiguration wird nicht mehr verwendet, ist aber hier dokumentiert:
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=llama3:8b
# OLLAMA_TIMEOUT_MS=90000
# USE_OLLAMA_ANALYSIS=false (Regex-Analyse ist kostenlos, sofort, und benötigt keine Tokens)

# Hinweis: Dokumentanalyse verwendet nun:
# 1. OCR (Tesseract) für Bilder: 1-2 Sekunden
# 2. Regex-basierte Feldextraktion: instant (~100ms)
# 3. Kein Ollama / LLM-Timeout mehr

# Claude AI Provider Configuration
# Interactive picker: node scripts/pick-provider.mjs
# Manual switch: node scripts/switch-provider.mjs [anthropic|openrouter|status]
CLAUDE_PROVIDER=anthropic                    # Options: anthropic | openrouter
CLAUDE_MODEL=claude-opus-4-7                 # Auto-detected per provider

# Anthropic API (Claude Pro)
ANTHROPIC_API_KEY=                           # sk-ant-... from https://console.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-7              # claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5

# OpenRouter API (Alternative provider)
OPENROUTER_API_KEY=                          # From https://openrouter.ai
OPENROUTER_MODEL=openrouter/free             # openrouter/free | openrouter/auto | claude-3-5-sonnet | etc.
